# ─────────────────────────────────────────────────────────────────────────────
# Ojiva AI — static export caching + compression for LiteSpeed / Apache hosting.
# public/_headers (Netlify/Cloudflare format) is a NO-OP on LiteSpeed, so these
# rules are what actually ship. Copied verbatim into out/ by the static export.
# ─────────────────────────────────────────────────────────────────────────────

# ── Compression (LiteSpeed honours mod_deflate; Brotli auto on LSWS) ──────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json application/xml image/svg+xml application/x-font-ttf application/vnd.ms-fontobject font/opentype
</IfModule>

# ── Cache-Control ─────────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  # Content-hashed Next.js build output → 1 year, immutable (safe: filename changes on rebuild)
  <If "%{REQUEST_URI} =~ m#^/_next/static/#">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </If>

  # Local icon font path → 1 year immutable
  <ElseIf "%{REQUEST_URI} =~ m#^/icons/#">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </ElseIf>

  # Fonts → 1 year immutable
  <ElseIf "%{REQUEST_URI} =~ m#\.(woff2?|ttf|otf|eot)$#">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </ElseIf>

  # Images + video → 30 days (names are stable but may be replaced on content edits)
  <ElseIf "%{REQUEST_URI} =~ m#\.(webp|avif|png|jpe?g|gif|svg|ico|mp4)$#">
    Header set Cache-Control "public, max-age=2592000"
  </ElseIf>

  # HTML documents → always revalidate so deploys go live immediately
  <ElseIf "%{REQUEST_URI} =~ m#(\.html|/)$#">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </ElseIf>
</IfModule>

# ── Long-cache the hashed static dir via ExpiresByType fallback ───────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/webp "access plus 30 days"
  ExpiresByType image/avif "access plus 30 days"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>
